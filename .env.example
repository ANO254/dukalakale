# Django Settings
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.railway.app,localhost,127.0.0.1

# Database (Railway will provide this automatically)
