{
  "version": 2,
  "builds": [
    {
      "src": "duka/wsgi.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.11" }
    },
    {
      "src": "requirements.txt",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "duka/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SECRET_KEY": "@secret",
    "DJANGO_DEBUG": "False",
    "DJANGO_ALLOWED_HOSTS": ".vercel.app",
    "PYTHON_VERSION": "3.11"
  }
}